# Environment
NODE_ENV=development
ENABLE_SWAGGER=true

# Server
PORT=3200

# Database
DATABASE_URL=postgresql://repeto:repeto_dev_2026@localhost:5434/repeto?schema=public

# Redis
REDIS_URL=redis://localhost:6380

# JWT
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (CORS)
# Comma-separated list is supported, e.g. https://app.repeto.ru,https://www.repeto.ru
FRONTEND_URL=http://localhost:3300

# ЮKassa (sandbox)
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=
# Optional: platform subscription billing (registration step 3). If empty, falls back to YUKASSA_SHOP_ID / YUKASSA_SECRET_KEY
YUKASSA_PLATFORM_SHOP_ID=
YUKASSA_PLATFORM_SECRET_KEY=

# Yandex Disk OAuth
YANDEX_DISK_CLIENT_ID=
YANDEX_DISK_CLIENT_SECRET=
# Optional: defaults to FRONTEND_URL/settings?tab=integrations&integration=yandex-disk
YANDEX_DISK_REDIRECT_URI=
# Optional DEV-only overrides (used when NODE_ENV!=production)
YANDEX_DISK_CLIENT_ID_DEV=
YANDEX_DISK_CLIENT_SECRET_DEV=
YANDEX_DISK_REDIRECT_URI_DEV=
# Optional: defaults to JWT_SECRET
YANDEX_DISK_STATE_SECRET=

# Yandex Calendar OAuth
YANDEX_CALENDAR_CLIENT_ID=
# Optional: if empty, uses YANDEX_DISK_REDIRECT_URI or FRONTEND_URL/settings?tab=integrations&integration=yandex-calendar
YANDEX_CALENDAR_REDIRECT_URI=
# Optional DEV-only overrides (used when NODE_ENV!=production)
YANDEX_CALENDAR_CLIENT_ID_DEV=
YANDEX_CALENDAR_REDIRECT_URI_DEV=

# Google Calendar OAuth
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=
# Optional DEV-only overrides (used when NODE_ENV!=production)
GOOGLE_CALENDAR_CLIENT_ID_DEV=
GOOGLE_CALENDAR_CLIENT_SECRET_DEV=
GOOGLE_CALENDAR_REDIRECT_URI_DEV=

# Google Drive OAuth
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=
# Optional DEV-only overrides (used when NODE_ENV!=production)
GOOGLE_DRIVE_CLIENT_ID_DEV=
GOOGLE_DRIVE_CLIENT_SECRET_DEV=
GOOGLE_DRIVE_REDIRECT_URI_DEV=

# SMTP (Mail.ru)
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=support@repeto.ru
# Password for external apps
SMTP_PASS=
SMTP_FROM_EMAIL=Repeto <support@repeto.ru>

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Web Push (VAPID)
# Generate once: npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:support@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Optional aliases (if used instead of VAPID_*)
WEB_PUSH_SUBJECT=
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=

# Messenger bots
TELEGRAM_BOT_TOKEN=
MAX_BOT_TOKEN=

# App
APP_URL=http://localhost:3200
