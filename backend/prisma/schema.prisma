generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Auth & Users ──

model User {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String @map("password_hash")
  name         String
  phone        String?
  whatsapp     String?
  slug         String? @unique
  published    Boolean @default(false)
  showPublicPackages Boolean @default(true) @map("show_public_packages")
  timezone     String  @default("Europe/Moscow")
  avatarUrl    String? @map("avatar_url")

  // Professional
  subjects       String[] @default([])
  subjectDetails Json?    @map("subject_details")
  aboutText      String?  @map("about_text")
  tagline        String?
  vk             String?
  website        String?
  format         String?
  offlineAddress String?  @map("offline_address")
  lessonsCount Int      @default(0) @map("lessons_count")
  rating       Decimal? @db.Decimal(2, 1)

  // Portfolio / credentials
  education              Json?    @map("education")
  experience             String?  @map("experience")
  qualificationVerified  Boolean  @default(false) @map("qualification_verified")
  qualificationLabel     String?  @map("qualification_label")
  certificates           Json?    @map("certificates")

  // Tax / legal
  taxStatus TaxStatus @default(INDIVIDUAL) @map("tax_status")
  taxInn    String?   @map("tax_inn")
  taxDisplayName String? @map("tax_display_name")

  // Settings (embedded JSON)
  notificationSettings Json? @map("notification_settings")
  cancelPolicySettings Json? @map("cancel_policy_settings")
  paymentSettings      Json? @map("payment_settings")

  // Integrations
  yukassaShopId       String? @map("yukassa_shop_id")
  yukassaSecretKey    String? @map("yukassa_secret_key")
  googleCalendarToken  Json?   @map("google_calendar_token")
  googleCalendarEmail  String? @map("google_calendar_email")
  yandexCalendarToken  Json?   @map("yandex_calendar_token")
  yandexCalendarEmail  String? @map("yandex_calendar_email")
  yandexCalendarLogin  String? @map("yandex_calendar_login")
  yandexDiskToken      Json?   @map("yandex_disk_token")
  yandexDiskRootPath  String? @map("yandex_disk_root_path")
  yandexDiskEmail     String? @map("yandex_disk_email")
  googleDriveToken    Json?   @map("google_drive_token")
  googleDriveRootPath String? @map("google_drive_root_path")
  googleDriveEmail    String? @map("google_drive_email")
  homeworkDefaultCloud CloudProvider @default(YANDEX_DISK) @map("homework_default_cloud")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  students      Student[]
  lessons       Lesson[]
  payments      Payment[]
  packages      Package[]
  notifications Notification[]
  files         FileRecord[]
  refreshTokens RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  availability  TutorAvailability[]
  availabilityOverrides AvailabilityOverride[]
  bookingRequests BookingRequest[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model RegistrationVerification {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  phone        String?
  passwordHash String   @map("password_hash")
  codeHash     String   @map("code_hash")
  legalVersion String?  @map("legal_version")
  legalDocumentHash String? @map("legal_document_hash")
  legalConsents Json?   @map("legal_consents")
  expiresAt    DateTime @map("expires_at")
  attempts     Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([expiresAt])
  @@map("registration_verifications")
}

enum TaxStatus {
  INDIVIDUAL
  SELF_EMPLOYED
  SOLE_TRADER
  LEGAL_ENTITY
}

model LegalVersion {
  id          String   @id @default(uuid())
  version     String   @unique
  title       String
  publishedAt DateTime @map("published_at")
  url         String
  hash        String
  active      Boolean  @default(false)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  consents LegalConsent[]

  @@index([active, publishedAt])
  @@map("legal_versions")
}

model LegalConsent {
  id             String   @id @default(uuid())
  legalVersionId String   @map("legal_version_id")
  userId         String?  @map("user_id")
  tutorId        String?  @map("tutor_id")
  consentType    String   @map("consent_type")
  occurredAt     DateTime @default(now()) @map("occurred_at")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  documentUrl    String   @map("document_url")
  documentAnchor String?  @map("document_anchor")
  documentVersion String  @map("document_version")
  documentHash   String?  @map("document_hash")
  checkboxText   String   @map("checkbox_text")
  granted        Boolean  @default(false)
  source         String
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")

  legalVersion LegalVersion @relation(fields: [legalVersionId], references: [id], onDelete: Restrict)

  @@index([userId, occurredAt])
  @@index([tutorId, occurredAt])
  @@index([consentType, occurredAt])
  @@index([source, occurredAt])
  @@map("legal_consents")
}

// ── Students ──

model Student {
  id      String        @id @default(uuid())
  userId  String        @map("user_id")
  name    String
  subject String
  grade   String?
  age     Int?
  rate    Int
  status  StudentStatus @default(ACTIVE)

  // Contacts
  phone    String?
  whatsapp String?
  telegram String? // legacy
  email    String?

  // Messenger chat IDs
  telegramChatId String? @map("telegram_chat_id")
  maxChatId      String? @map("max_chat_id")

  // Parent
  parentName     String? @map("parent_name")
  parentPhone    String? @map("parent_phone")
  parentWhatsapp String? @map("parent_whatsapp")
  parentTelegram String? @map("parent_telegram") // legacy
  parentEmail    String? @map("parent_email")

  notes String?

  // Student self-service account (one-to-many: account → per-tutor Student rows)
  accountId String? @map("account_id")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  account       StudentAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  lessons       Lesson[]
  payments      Payment[]
  packages      Package[]
  lessonNotes   LessonNote[]
  homework      Homework[]
  notifications Notification[]
  fileShares    FileShare[]

  @@index([userId, status])
  @@index([userId, name])
  @@index([accountId])
  @@map("students")
}

enum StudentStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

// ── Student Accounts (self-service portal) ──

model StudentAccount {
  id              String               @id @default(uuid())
  email           String               @unique
  name            String
  avatarUrl       String?              @map("avatar_url")
  status          StudentAccountStatus @default(INVITED)
  emailVerifiedAt DateTime?            @map("email_verified_at")
  lastLoginAt     DateTime?            @map("last_login_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  students      Student[]
  refreshTokens StudentRefreshToken[]

  @@map("student_accounts")
}

enum StudentAccountStatus {
  INVITED
  ACTIVE
  PAUSED
}

model StudentOtp {
  id        String           @id @default(uuid())
  email     String
  codeHash  String           @map("code_hash")
  purpose   StudentOtpPurpose @default(LOGIN)
  expiresAt DateTime         @map("expires_at")
  attempts  Int              @default(0)
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([email, purpose])
  @@index([expiresAt])
  @@map("student_otps")
}

enum StudentOtpPurpose {
  LOGIN
  BOOKING
}

model StudentRefreshToken {
  id        String   @id @default(uuid())
  accountId String   @map("account_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  account StudentAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("student_refresh_tokens")
}

// ── Lessons ──

model Lesson {
  id          String       @id @default(uuid())
  userId      String       @map("user_id")
  studentId   String       @map("student_id")
  subject     String
  scheduledAt DateTime     @map("scheduled_at")
  duration    Int
  format      LessonFormat @default(ONLINE)
  location    String?
  rate        Int
  status      LessonStatus @default(PLANNED)

  // Recurrence
  recurrenceGroupId String? @map("recurrence_group_id")

  // Cancellation
  cancelReason     String?   @map("cancel_reason")
  cancelledAt      DateTime? @map("cancelled_at")
  lateCancelCharge Int?      @map("late_cancel_charge")

  // Reschedule
  rescheduleNewTime DateTime? @map("reschedule_new_time")

  // Calendar sync
  googleCalendarEventId  String? @map("google_calendar_event_id")
  yandexCalendarEventUid String? @map("yandex_calendar_event_uid")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  student       Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  notes         LessonNote[]
  homework      Homework[]
  payments      Payment[]
  notifications Notification[]

  @@index([userId, scheduledAt])
  @@index([studentId, scheduledAt])
  @@index([userId, status, scheduledAt])
  @@index([googleCalendarEventId])
  @@index([yandexCalendarEventUid])
  @@index([recurrenceGroupId])
  @@map("lessons")
}

enum LessonFormat {
  ONLINE
  OFFLINE
}

enum LessonStatus {
  PLANNED
  COMPLETED
  CANCELLED_STUDENT
  CANCELLED_TUTOR
  NO_SHOW
  RESCHEDULE_PENDING
}

// ── Notes ──

model LessonNote {
  id        String  @id @default(uuid())
  studentId String  @map("student_id")
  lessonId  String? @map("lesson_id")
  content   String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson  Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@index([studentId, createdAt])
  @@map("lesson_notes")
}

// ── Homework ──

model Homework {
  id          String         @id @default(uuid())
  studentId   String         @map("student_id")
  lessonId    String?        @map("lesson_id")
  task        String
  dueAt       DateTime?      @map("due_at")
  status      HomeworkStatus @default(PENDING)
  attachments String[]       @default([])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson  Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  materials HomeworkMaterial[]

  @@index([studentId, dueAt])
  @@map("homework")
}

enum HomeworkStatus {
  PENDING
  COMPLETED
  OVERDUE
}

model HomeworkMaterial {
  id         String @id @default(uuid())
  homeworkId String @map("homework_id")
  fileId     String @map("file_id")

  createdAt DateTime @default(now()) @map("created_at")

  homework Homework  @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  file     FileRecord @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([homeworkId, fileId])
  @@index([fileId])
  @@map("homework_materials")
}

// ── Payments ──

model Payment {
  id        String        @id @default(uuid())
  userId    String        @map("user_id")
  studentId String        @map("student_id")
  lessonId  String?       @map("lesson_id")
  amount    Int
  method    PaymentMethod
  status    PaymentStatus @default(PENDING)
  date      DateTime      @default(now())
  comment   String?

  // ЮKassa
  externalPaymentId String? @unique @map("external_payment_id")

  // Receipt (НПД)
  receiptStatus ReceiptStatus @default(NOT_NEEDED) @map("receipt_status")
  receiptUrl    String?       @map("receipt_url")

  // Package link
  packageId String? @map("package_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  student Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson  Lesson?  @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  package Package? @relation(fields: [packageId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([studentId, status])
  @@index([lessonId])
  @@index([userId, status])
  @@index([userId, status, date])
  @@map("payments")
}

enum PaymentMethod {
  SBP
  CASH
  TRANSFER
  YUKASSA
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  REFUNDED
}

enum ReceiptStatus {
  NOT_NEEDED
  NEEDED
  ATTACHED
}

// ── Packages ──

model Package {
  id           String        @id @default(uuid())
  userId       String        @map("user_id")
  studentId    String?       @map("student_id")
  isPublic     Boolean       @default(false) @map("is_public")
  subject      String
  lessonsTotal Int           @map("lessons_total")
  lessonsUsed  Int           @default(0) @map("lessons_used")
  totalPrice   Int           @map("total_price")
  comment      String?
  status       PackageStatus @default(ACTIVE)
  validUntil   DateTime?     @map("valid_until")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  student  Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)
  payments Payment[]
  bookingRequests BookingRequest[]

  @@index([userId, status])
  @@index([userId, isPublic, status])
  @@index([studentId])
  @@map("packages")
}

enum PackageStatus {
  ACTIVE
  COMPLETED
  EXPIRED
}

// ── Notifications ──

model Notification {
  id               String           @id @default(uuid())
  userId           String           @map("user_id")
  studentId        String?          @map("student_id")
  lessonId         String?          @map("lesson_id")
  bookingRequestId String?          @map("booking_request_id")
  type             NotificationType
  title            String
  description      String
  read             Boolean          @default(false)
  actionUrl        String?          @map("action_url")

  // Delivery
  channel NotificationChannel?
  sentAt  DateTime?            @map("sent_at")

  createdAt DateTime @default(now()) @map("created_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  student        Student?        @relation(fields: [studentId], references: [id], onDelete: SetNull)
  lesson         Lesson?         @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  bookingRequest BookingRequest? @relation(fields: [bookingRequestId], references: [id], onDelete: SetNull)

  @@index([userId, read, createdAt])
  @@index([userId, type])
  @@index([userId, type, createdAt])
  @@map("notifications")
}

enum NotificationType {
  PAYMENT_RECEIVED
  PAYMENT_OVERDUE
  LESSON_REMINDER
  LESSON_CANCELLED
  RESCHEDULE_REQUESTED
  HOMEWORK_SUBMITTED
  PACKAGE_EXPIRING
  BOOKING_NEW
  BOOKING_CONFIRMED
  BOOKING_REJECTED
  SYSTEM
}

enum NotificationChannel {
  EMAIL
  PUSH
  WHATSAPP
  SMS
  TELEGRAM
  MAX
}

// ── Files ──

model FileRecord {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  name          String
  type          FileType
  extension     String?
  size          String?
  cloudProvider CloudProvider @map("cloud_provider")
  cloudUrl      String        @map("cloud_url")
  parentId      String?       @map("parent_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  shares FileShare[]
  homeworkMaterials HomeworkMaterial[]

  @@index([userId, parentId])
  @@map("files")
}

model FileShare {
  id        String @id @default(uuid())
  fileId    String @map("file_id")
  studentId String @map("student_id")

  createdAt DateTime @default(now()) @map("created_at")

  file    FileRecord @relation(fields: [fileId], references: [id], onDelete: Cascade)
  student Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([fileId, studentId])
  @@map("file_shares")
}

enum FileType {
  FILE
  FOLDER
}

enum CloudProvider {
  YANDEX_DISK
  GOOGLE_DRIVE
}

// ── Audit Log ──

model AuditLog {
  id       String  @id @default(uuid())
  userId   String? @map("user_id")
  action   String
  entity   String
  entityId String  @map("entity_id")
  details  Json?
  ip       String?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}

// ── Tutor Availability ──

model TutorAvailability {
  id        String @id @default(uuid())
  userId    String @map("user_id")
  dayOfWeek Int    @map("day_of_week") // 0=Mon, 1=Tue, ..., 6=Sun
  startTime String @map("start_time")  // "09:00"
  endTime   String @map("end_time")    // "09:30"

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dayOfWeek, startTime])
  @@index([userId, dayOfWeek])
  @@map("tutor_availability")
}

model AvailabilityOverride {
  id     String @id @default(uuid())
  userId String @map("user_id")
  date   DateTime @db.Date          // конкретная дата
  startTime String @map("start_time")
  endTime   String @map("end_time")
  isBlocked Boolean @default(false) @map("is_blocked") // true = убрать слот, false = добавить

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, startTime])
  @@index([userId, date])
  @@map("availability_overrides")
}

// ── Booking Requests ──

model BookingRequest {
  id         String        @id @default(uuid())
  userId     String        @map("user_id") // tutor's userId
  packageId  String?       @map("package_id")
  subject    String
  date       DateTime      @db.Date
  startTime  String        @map("start_time")
  duration   Int           @default(30)

  // Requester info
  clientName  String @map("client_name")
  clientPhone String @map("client_phone")
  clientEmail String? @map("client_email")
  comment     String?

  // Messenger chat IDs (captured during booking via deep link)
  telegramChatId String? @map("telegram_chat_id")
  maxChatId      String? @map("max_chat_id")

  status BookingStatus @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  package Package? @relation(fields: [packageId], references: [id], onDelete: SetNull)
  notifications Notification[]

  @@index([userId, status])
  @@index([userId, date])
  @@index([packageId])
  @@map("booking_requests")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}
